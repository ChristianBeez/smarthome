<!doctype html>
<html>

<head>
    <title>HomeConnect</title>
    <link rel="stylesheet" type="text/css" href="../static/style.css">
    <script type="text/javascript" src="https://ajax.googleapis.com/ajax/libs/jquery/2.1.3/jquery.min.js"></script>
    <script src="../static/java.js"></script>
    <script src="../static/modbus.js"></script>
    <style>
        .config-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 18px 20px;
            margin: 10px 0;
            background: #f9f9f9;
            border-radius: 10px;
            border: 1px solid #ddd;
        }
        .config-item p { margin: 4px 0 0 0; color: #888; font-size: 0.9em; }
        .toggle { position: relative; display: inline-block; width: 56px; height: 30px; flex-shrink: 0; }
        .toggle input { opacity: 0; width: 0; height: 0; }
        .slider {
            position: absolute; cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #ccc; border-radius: 30px;
            transition: .3s;
        }
        .slider:before {
            position: absolute; content: "";
            height: 22px; width: 22px; left: 4px; bottom: 4px;
            background-color: white; border-radius: 50%; transition: .3s;
        }
        input:checked + .slider { background-color: #4CAF50; }
        input:checked + .slider:before { transform: translateX(26px); }
    </style>
    <script type=text/javascript>$SCRIPT_ROOT = {{ request.script_root | tojson }};</script>
    <script>
        function ladeConfig() {
            fetch('/api/config')
                .then(r => r.json())
                .then(cfg => {
                    document.getElementById('toggle-extremeHot').checked = cfg.extremeHot;
                    document.getElementById('toggle-christmas').checked = cfg.christmas;
                    document.getElementById('toggle-SchlafRollo').checked = cfg.SchlafRollo;
                });
        }
        function setConfig(key, value) {
            fetch('/api/config', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({key: key, value: value})
            }).then(r => r.json()).then(data => {
                if (data.success) {
                    var s = document.getElementById('config-status');
                    s.style.display = 'block';
                    setTimeout(() => s.style.display = 'none', 2000);
                }
            });
        }
    </script>
</head>

<body>
    <nav class="slidemenu">

        <!-- Item 1 -->
        <input type="radio" name="slideItem" id="slide-item-1" class="slide-toggle" onclick="openTab(event, 'smarthome')" checked />
        <label for="slide-item-1"><p class="icon">♬</p><span>Smart Home</span></label>

        <!-- Item 2 -->
        <input type="radio" name="slideItem" id="slide-item-2" class="slide-toggle" onclick="openTab(event, 'kalender')" />
        <label for="slide-item-2"><p class="icon">★</p><span>Kalender</span></label>

        <!-- Item 3 -->
        <input type="radio" name="slideItem" id="slide-item-3" class="slide-toggle" onclick="openTab(event, 'solar')" />
        <label for="slide-item-3"><p class="icon">✈</p><span>Photovoltaik</span></label>

        <!-- Item 4 -->
        <input type="radio" name="slideItem" id="slide-item-4" class="slide-toggle" onclick="openTab(event, 'wetter')" />
        <label for="slide-item-4"><p class="icon">✎</p><span>Wetter</span></label>

        <!-- Item 5 -->
        <input type="radio" name="slideItem" id="slide-item-5" class="slide-toggle" onclick="openTab(event, 'boerse')" />
        <label for="slide-item-5"><p class="icon">✎</p><span>Börse</span></label>

        <!-- Item 6 -->
        <input type="radio" name="slideItem" id="slide-item-6" class="slide-toggle" onclick="openTab(event, 'einstellungen'); ladeConfig();" />
        <label for="slide-item-6"><p class="icon">⚙</p><span>Einstellungen</span></label>

        <div class="clear"></div>

        <!-- Bar -->
        <div class="slider">
            <div class="bar"></div>
        </div>
    </nav>

